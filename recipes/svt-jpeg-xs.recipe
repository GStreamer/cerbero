# -*- Mode: Python -*- vi:si:et:sw=4:sts=4:ts=4:syntax=python
from pathlib import Path
import shutil

from cerbero.enums import Symbolication
from cerbero.tools.libtool import LibtoolLibrary

class SvtJpegXsBase:
    version = '0.9.0'
    stype = SourceType.TARBALL
    btype = BuildType.CMAKE
    can_msvc = True
    url = 'https://github.com/OpenVisualCloud/SVT-JPEG-XS/archive/refs/tags/v%(version)s.tar.gz'
    tarball_dirname = 'SVT-JPEG-XS-%(version)s'
    tarball_checksum = 'ff5dfb3b98348a39049da4fd3062d3391cbadec4c4b61825a9f3435ca671effa'
    # third_party/cpuinfo has compatibility set to 2.8.12
    configure_options = [
        '-DNATIVE=OFF',
        '-DBUILD_APPS=OFF',
        '-DBUILD_TESTING=OFF',
        '-DCMAKE_POLICY_VERSION_MINIMUM=3.5',
    ]
    library_type = LibraryType.STATIC

    def prepare(self):
        if self.config.target_arch in (Architecture.X86, Architecture.X86_64):
            self.configure_options.append('-DENABLE_NASM=ON')
        # Fix output directory for symbolication (shared) and copy (static)
        self.configure_options.append(f'-DCMAKE_OUTPUT_DIRECTORY={self.build_dir}/Bin/')


class SvtJpegXsStaticRecipe(SvtJpegXsBase, recipe.Recipe):
    name = 'svt-jpeg-xs-static'

    async def install(self):
        name = 'SvtJpegxs.lib' if self.using_msvc() else 'libSvtJpegxs.a'
        src = Path(self.build_dir) / 'Bin' / name
        dest = Path(self.config.libdir) / 'libSvtJpegxs.a'
        shutil.copy(src, dest)


class SvtJpegXsRecipe(SvtJpegXsBase, recipe.Recipe):
    name = 'svt-jpeg-xs'
    library_type = LibraryType.BOTH
    licenses = [{License.BSD_2_Clause_Patent: ['LICENSE.md']}]
    deps = ['svt-jpeg-xs-static']

    files_libs = ['libSvtJpegxs']
    files_devel = [
        'include/svt-jpegxs/',
        '%(libdir)s/pkgconfig/SvtJpegxs.pc'
    ]

    def prepare(self):
        super().prepare()

        if self.config.variants.visualstudio:
            self.symbolication_patterns = {
                Symbolication.SKIP: [],
                Symbolication.MANUAL: ['SvtJpegxs']
            }

    # https://github.com/OpenVisualCloud/SVT-JPEG-XS/blob/e1030c6c8ee2fb05b76c3fa14cccf8346db7a1fa/Source/Lib/CMakeLists.txt#L91
    async def install(self):
        await super(recipe.Recipe, self).install()
        if self.config.target_platform == Platform.WINDOWS:
            lib = f"{'' if self.using_msvc() else 'lib'}SvtJpegxs.dll"
            src = Path(self.config.libdir) / lib
            src.replace(
                Path(self.config.prefix) / 'bin' / lib
            )

    def post_install(self):
        libtool_la = LibtoolLibrary('SvtJpegxs', None, None, None, self.config.libdir,
                self.config.target_platform, [])
        libtool_la.save()
        super().post_install()
