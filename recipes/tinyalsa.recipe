# -*- Mode: Python -*- vi:si:et:sw=4:sts=4:ts=4:syntax=python
from cerbero.tools.libtool import LibtoolLibrary


class Recipe(recipe.Recipe):

    name = 'tinyalsa'
    version = '2.0.0.r28'
    licenses = [{License.BSD_3_Clause: ['NOTICE']}]
    stype = SourceType.TARBALL
    btype = BuildType.MESON
    # Mirrored because the original source tarball is generated one, so the checksum keeps varying
    # source: https://android.googlesource.com/platform/external/tinyalsa_new/+archive/android-15.0.0_r28.tar.gz
    url = f'https://gstreamer.freedesktop.org/src/mirror/tinyalsa/tinyalsa-{version}.tar.xz'
    tarball_checksum = 'd4c73a097c771db7c25d223266ab8056e61a94a997b9a263b6e8e58beacd7122'

    platform_deps = {
        Platform.LINUX: ['libpulse'],
    }

    meson_options = {
        'docs': 'disabled',
        'examples': 'disabled',
        'utils': 'disabled',
    }

    files_libs = [ 'libtinyalsa' ]

    files_devel = [ 'include/tinyalsa', '%(libdir)s/pkgconfig/tinyalsa.pc' ]

    def prepare(self):
        if self.config.target_platform not in (Platform.LINUX, Platform.ANDROID):
            raise InvalidRecipeError(self, "Invalid platform")

    def post_install(self):
        LibtoolLibrary('tinyalsa', 2, 0, 0, self.config.libdir,
                self.config.target_platform).save()
        super().post_install()
