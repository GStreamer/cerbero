# -*- Mode: Python -*- vi:si:et:sw=4:sts=4:ts=4:syntax=python

from cerbero.tools.libtool import LibtoolLibrary

from pathlib import Path
import shutil


class VvdecBase:
    version = '3.1.0'
    stype = SourceType.TARBALL
    url = 'https://github.com/fraunhoferhhi/vvdec/archive/refs/tags/v%(version)s.tar.gz'
    tarball_checksum = 'e3e5093acfdcbfd2159f3d0166d451d7ccabd293ed30f3762b481c9c6c0a7512'
    tarball_dirname = 'vvdec-%(version)s'

    patches = [
        'vvdec/0001-Do-not-set-_WIN32_WINNT-in-CMake.patch',
        'vvdec/0002-Remove-include-stdio.h-from-sei.h.patch'
    ]
    can_msvc = True

    btype = BuildType.CMAKE
    library_type = LibraryType.STATIC
    configure_options = ['-DVVDEC_TOPLEVEL_OUTPUT_DIRS=OFF']

    def prepare(self):
        # Bitcode breaks xcodebuild archiving
        #
        # -flto is broken on x86 windows:
        # https://gitlab.freedesktop.org/gstreamer/cerbero/-/merge_requests/2014#note_3245062
        if Platform.is_apple(self.config.target_platform) or \
            (self.config.target_platform == Platform.WINDOWS and
             self.config.target_arch == Architecture.X86):
            self.configure_options.append('-DVVDEC_ENABLE_LINK_TIME_OPT=OFF')

        if Platform.is_apple(self.config.target_platform):
            self.append_env('CXXFLAGS', '-Wno-error=nontrivial-memcall', '-Wno-error=unknown-warning-option')

        if self.config.target_platform == Platform.ANDROID:
            # VVdeC uses exceptions internally
            self.append_env('CXXFLAGS', '-frtti', '-fexceptions')

            # No NEON on ARMv7
            if self.config.target_arch == Architecture.ARMv7:
                self.configure_options.append('-DVVDEC_ENABLE_ARM_SIMD=OFF')

class VvdecStaticRecipe(VvdecBase, recipe.Recipe):
    name = 'vvdec-static'

    def prepare(self):
        super().prepare()

    async def install(self):
        name = 'vvdec.lib' if self.using_msvc() else 'libvvdec.a'
        src = Path(self.build_dir) / 'lib' / name
        dest = Path(self.config.libdir) / 'libvvdec.a'
        shutil.copy(src, dest)

class VvdecRecipe(VvdecBase, recipe.Recipe):
    name = 'vvdec'
    deps = ['vvdec-static']
    licenses = [{License.BSD_3_Clause_Clear: ['LICENSE.txt']}]
    library_type = LibraryType.BOTH

    files_libs = ['libvvdec']
    files_devel = ['include/vvdec', '%(libdir)s/pkgconfig/libvvdec.pc']

    def post_install(self):
        libtool_la = LibtoolLibrary('vvdec', None, None, None, self.config.libdir,
                                    self.config.target_platform)
        libtool_la.save()
        super().post_install()
