+++ b/tls/openssl/gtlsconnection-openssl.c
@@ -166,7 +166,6 @@ end_openssl_io (GTlsConnectionOpenssl  *openssl,
         }
     }
 
-#ifdef SSL_R_SHUTDOWN_WHILE_IN_INIT
