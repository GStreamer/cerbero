From 07fe5120e68db576a12ae0caafab26edcdfac29c Mon Sep 17 00:00:00 2001
From: Michael Catanzaro <mcatanzaro@gnome.org>
Date: Fri, 10 Apr 2026 09:49:33 -0500
Subject: [PATCH 14/14] Require OpenSSL 1.1.1 or newer

This is the version available in RHEL 8.

Also, check OPENSSL_VERSION rather than for macro existence when testing
for SSL_R_UNEXPECTED_EOF_WHILE_READING. Although this is less specific,
it makes it easier to know when we can safely remove the preprocessor
guard in the future.

Part-of: <https://gitlab.gnome.org/GNOME/glib-networking/-/merge_requests/277>
---
 tls/openssl/gtlsbio.c                      | 107 +--------------------
 tls/openssl/gtlsclientconnection-openssl.c |  28 +-----
 tls/openssl/gtlsconnection-openssl.c       |  12 +--
 tls/openssl/gtlsserverconnection-openssl.c |  62 +-----------
 4 files changed, 10 insertions(+), 199 deletions(-)

diff --git a/tls/openssl/gtlsbio.c b/tls/openssl/gtlsbio.c
index 8270cf2..6656d76 100644
--- a/tls/openssl/gtlsbio.c
+++ b/tls/openssl/gtlsbio.c
@@ -57,16 +57,9 @@ free_gbio (gpointer user_data)
 static int
 gtls_bio_create (BIO *bio)
 {
-#if OPENSSL_VERSION_NUMBER < 0x10100000L || defined (LIBRESSL_VERSION_NUMBER)
-  bio->init = 0;
-  bio->num = 0;
-  bio->ptr = NULL;
-  bio->flags = 0;
-#else
   BIO_set_init (bio, 0);
   BIO_set_data (bio, NULL);
   BIO_clear_flags (bio, ~0);
-#endif
   return 1;
 }
 
@@ -76,18 +69,6 @@ gtls_bio_destroy (BIO *bio)
   if (!bio)
     return 0;
 
-#if OPENSSL_VERSION_NUMBER < 0x10100000L || defined (LIBRESSL_VERSION_NUMBER)
-  if (bio->shutdown)
-    {
-      if (bio->ptr)
-        {
-          free_gbio (bio->ptr);
-          bio->ptr = NULL;
-        }
-      bio->init = 0;
-      bio->flags = 0;
-    }
-#else
   if (BIO_get_shutdown (bio))
     {
       if (BIO_get_data (bio))
@@ -98,7 +79,6 @@ gtls_bio_destroy (BIO *bio)
       BIO_clear_flags (bio, ~0);
       BIO_set_init (bio, 0);
     }
-#endif
 
     return 1;
 }
@@ -109,30 +89,16 @@ gtls_bio_ctrl (BIO  *b,
