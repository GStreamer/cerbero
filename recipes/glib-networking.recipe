# -*- Mode: Python -*- vi:si:et:sw=4:sts=4:ts=4:syntax=python
import os
from cerbero.tools.libtool import LibtoolLibrary

class Recipe(recipe.Recipe):
    name = 'glib-networking'
    version = '2.80.1'
    licenses = [{License.LGPLv2Plus: None, License.Misc: ['LICENSE_EXCEPTION']}]
    stype = SourceType.TARBALL
    btype = BuildType.MESON
    url = 'gnome://'
    tarball_checksum = 'b80e2874157cd55071f1b6710fa0b911d5ac5de106a9ee2a4c9c7bee61782f8e'

    # static_modules is now governed by default_library
    # https://gitlab.gnome.org/GNOME/glib-networking/-/commit/270d54a5ef9a3c9cb96997dbe0fbcb329dbf80e8
    meson_options = {'libproxy': 'enabled', 'gnome_proxy': 'disabled',
                     'gnutls': 'disabled', 'openssl': 'enabled'}
    deps = ['glib', 'libproxy', 'openssl']

    patches = [
        'glib-networking/0001-openssl-properly-check-return-value-when-writing-to-.patch',
        'glib-networking/0002-openssl-check-return-value-of-g_tls_bio_alloc.patch',
        'glib-networking/0003-openssl-check-return-values-of-BIO_new.patch',
        'glib-networking/0004-openssl-delete-support-for-OCSP-stapling.patch',
        'glib-networking/0005-Remove-support-for-rehandshaking.patch',
        'glib-networking/0006-openssl-fix-out-of-bounds-read-in-accepted-cas-prope.patch',
        'glib-networking/0007-openssl-fix-error-checking-in-certificate-getter.patch',
        'glib-networking/0008-openssl-Fix-race-when-initializing-extra-data-index.patch',
        'glib-networking/0009-openssl-reduce-the-scope-of-methods_gtls.patch',
        'glib-networking/0010-openssl-fix-memory-leak-if-BIO-initialization-fails.patch',
        'glib-networking/0011-openssl-fix-race-when-initializing-methods_gtls.patch',
        'glib-networking/0012-openssl-fix-whitespace.patch',
        'glib-networking/0013-Rename-get_server_identity-functions.patch',
        'glib-networking/0014-Require-OpenSSL-1.1.1-or-newer.patch',
    ]

    files_plugins = [
        '%(libdir)s/gio/modules/libgiolibproxy%(mext)s',
        '%(libdir)s/gio/modules/libgioopenssl%(mext)s',
    ]
    files_plugins_devel = []
    files_lang = ['glib-networking']
    files_devel = []

    def prepare(self):
        # Glib doesn't support static libraries on Windows yet
        if self.config.target_platform == Platform.WINDOWS:
            self.library_type = LibraryType.SHARED
        else:
            self.files_plugins_devel += [
                '%(libdir)s/gio/modules/libgiolibproxy.a',
                '%(libdir)s/gio/modules/libgioopenssl.a',
            ]
            # Only generated when building the static module
            self.files_plugins_devel += [
                '%(libdir)s/gio/modules/pkgconfig/giolibproxy.pc',
                '%(libdir)s/gio/modules/pkgconfig/gioopenssl.pc',
            ]

    def post_install(self):
        if self.config.target_platform != Platform.WINDOWS:
            # Meson does not generate la files
            LibtoolLibrary('gioopenssl', None, None, None,
                    os.path.join(self.config.libdir, 'gio', 'modules'),
                    self.config.target_platform, deps=['ssl', 'crypto']).save()
        super().post_install()
